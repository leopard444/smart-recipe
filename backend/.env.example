# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret

# Database
DATABASE_URL=mysql://recipe_user:recipe_pass@localhost:3306/smart_recipe
DEV_DATABASE_URL=mysql://recipe_user:recipe_pass@localhost:3306/smart_recipe

# Redis
REDIS_URL=redis://localhost:6379/0
DEV_REDIS_URL=redis://localhost:6379/0

# LLM API
LLM_API_KEY=your-openai-api-key
LLM_API_BASE=https://api.openai.com
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_CACHE_TTL=86400

# Rate Limiting
RATE_LIMIT_AI_GENERATE=20

# Upload
UPLOADS_DIR=./uploads

# Backup
BACKUP_DIR=./backups
ENABLE_SCHEDULER=false

# Server
PORT=5000
WORKERS=4
LOG_LEVEL=info

# MySQL (for Docker)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=smart_recipe
MYSQL_USER=recipe_user
MYSQL_PASSWORD=recipe_pass
MYSQL_HOST=mysql
